# =============================================================================
# 🔑 LLM PROVIDERS (Choose at least one)
# =============================================================================
# Google Gemini (FREE - Recommended)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (Paid - Premium quality)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (Optional)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# =============================================================================
# 🌐 SEARCH & WEB SCRAPING APIs
# =============================================================================
# Tavily AI Search (FREE 1000 calls/month)
# Get from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Firecrawl - Advanced web scraping (FREE tier available)
# Get from: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# =============================================================================
# 🛠️ TOOL-SPECIFIC APIs
# =============================================================================
# GitHub Personal Access Token (Optional - for higher rate limits)
# Get from: https://github.com/settings/tokens
# Permissions needed: public_repo (read-only)
GITHUB_TOKEN=your_github_token_here

# OpenWeather API (FREE 1000 calls/day)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# =============================================================================
# 🎤 VOICE SUPPORT (Optional)
# =============================================================================
# OpenAI API key is used for both Whisper (STT) and TTS
# Already set above

# Google Cloud credentials (Optional alternative)
# GOOGLE_CLOUD_API_KEY=your_google_cloud_key_here

# ElevenLabs (Premium TTS - Optional)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here

# =============================================================================
# 📝 OUTPUT INTEGRATIONS (Optional)
# =============================================================================
# Notion API
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_token_here
NOTION_PARENT_PAGE_ID=your_page_id_here

# =============================================================================
# 💾 MEMORY & CACHING (Optional)
# =============================================================================
# Redis (for advanced caching)
REDIS_URL=redis://localhost:6379/0

# ChromaDB persistence
CHROMA_PERSIST_DIR=./chroma_db

# =============================================================================
# 📊 MONITORING & OBSERVABILITY (Optional)
# =============================================================================
# LangSmith - LangChain monitoring
# Get from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=ai-ops-assistant

# =============================================================================
# ⚙️ APPLICATION SETTINGS
# =============================================================================
# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug Mode
DEBUG=true
LOG_LEVEL=INFO